<!-- Setup the detailed resolution. -->
<script>
    System.setResolutionDetailMapCallback(function() {
        var url = new URL('<%=packResolutionDetailMapURL%>', window.location);
        return fetch(url).then(function (response) {
            return response.json();
        }).then(function (json) {
            return { json, url: url.href };
        });
    });
</script>

<script src="/scripting/engine/bin/.cache/dev-cli/web/bundled/index.js"></script>

<!-- Manifest file. -->
<script name="setting" src="<%=settingsJs%>"></script>

<script>
    (function registerPrerequisiteImports() {
        var settings = window._CCSettings || {};
        var assets = settings.assets || {};
        var bundles = Array.from(new Set([].concat(assets.projectBundles || [], assets.remoteBundles || [])));
        bundles.forEach(function(bundle) {
            System.register(
                "virtual:///prerequisite-imports/" + bundle,
                [window.location.origin + "/assets/" + bundle + "/index.js"],
                function () {
                    return {
                        setters: [function () {}],
                        execute: function () {},
                    };
                },
            );
        });
    })();

    function installSceneSelector() {
        var selector = document.querySelector('#scene-select');
        if (!selector) {
            return;
        }
        var sceneListUrl = new URL('/scene-list', window.location);
        var currentUrl = new URL(window.location.href);
        var currentScene = currentUrl.searchParams.get('scene');
        if (currentScene) {
            sceneListUrl.searchParams.set('scene', currentScene);
        }
        fetch(sceneListUrl.href).then(function(response) {
            return response.json();
        }).then(function(data) {
            var scenes = data.scenes || [];
            selector.innerHTML = '';
            if (!scenes.length) {
                var emptyOption = document.createElement('option');
                emptyOption.value = '';
                emptyOption.textContent = 'No scenes';
                selector.appendChild(emptyOption);
                selector.disabled = true;
                return;
            }
            scenes.forEach(function(scene) {
                var option = document.createElement('option');
                option.value = scene.uuid;
                option.textContent = scene.url + (scene.bundle ? ' [' + scene.bundle + ']' : '');
                option.title = scene.name || scene.url;
                selector.appendChild(option);
            });
            selector.value = data.currentScene || '';
            selector.disabled = false;
        }).catch(function(error) {
            console.error(error);
        });
        selector.addEventListener('change', function() {
            if (!selector.value) {
                return;
            }
            var nextUrl = new URL(window.location.href);
            if (nextUrl.searchParams.get('scene') === selector.value) {
                return;
            }
            nextUrl.searchParams.set('scene', selector.value);
            window.location.href = nextUrl.href;
        });
    }

    window.onload = function() {
        installSceneSelector();
        System.import("/preview-app/index.js").then(function (mod) {
            return mod.bootstrap({
                engineBaseUrl: '/scripting/engine',
                settings: window._CCSettings,
                devices: <%-JSON.stringify(devices)%>,
            });
        }).catch(function(err) {
            console.error(err);
        });
    };
</script>
